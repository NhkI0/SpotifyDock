<Window x:Class="SpotifyDock.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SpotifyDock.ViewModels"
        Title="SpotifyDock"
        Width="360" Height="80"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        FontFamily="Segoe UI">

    <Window.DataContext>
        <vm:PlayerViewModel />
    </Window.DataContext>

    <Border x:Name="MainBorder" CornerRadius="12" Padding="10,8"
            BorderBrush="#2A2A48" BorderThickness="1"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1E1E36" Offset="0" />
                <GradientStop Color="#16162B" Offset="1" />
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="15"
                ShadowDepth="2" Opacity="0.4" Direction="270" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition x:Name="ProgressRow" Height="6" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition x:Name="TimeColumn" Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Album Art -->
                <Grid Grid.Column="0" Cursor="Hand"
                      MouseLeftButtonDown="AlbumArt_Click">
                    <Border Width="44" Height="44" CornerRadius="8"
                            Visibility="{Binding IsConnected,
                            Converter={StaticResource
                                BoolToVisibilityConverter}}">
                        <Border.Effect>
                            <DropShadowEffect
                                Color="{StaticResource SpotifyGreen}"
                                BlurRadius="12" ShadowDepth="0"
                                Opacity="0.25" />
                        </Border.Effect>
                    </Border>
                    <Border x:Name="AlbumArtBorder"
                            Width="44" Height="44"
                            CornerRadius="8" Background="#252545">
                        <Grid>
                            <Image Source="{Binding AlbumArt}"
                                   Stretch="UniformToFill"
                                   RenderOptions.BitmapScalingMode=
                                       "HighQuality">
                                <Image.Clip>
                                    <RectangleGeometry
                                        x:Name="AlbumArtClip"
                                        Rect="0,0,44,44"
                                        RadiusX="8" RadiusY="8" />
                                </Image.Clip>
                            </Image>
                            <TextBlock Text="&#x266B;" FontSize="20"
                                Foreground="{StaticResource GreenBrush}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Visibility="{Binding AlbumArt,
                                Converter={StaticResource
                                    NullToVisibleConverter}}" />
                        </Grid>
                    </Border>
                </Grid>

                <!-- Track Info -->
                <Grid Grid.Column="1" Margin="10,0,8,0"
                      VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="TxtTrack" Grid.Row="0"
                        Text="{Binding TrackName}"
                        Foreground="{StaticResource TextPrimary}"
                        FontSize="12.5" FontWeight="SemiBold"
                        TextTrimming="CharacterEllipsis" />
                    <TextBlock x:Name="TxtArtist" Grid.Row="1"
                        Text="{Binding ArtistName}"
                        Foreground="{StaticResource TextSecondary}"
                        FontSize="10.5"
                        TextTrimming="CharacterEllipsis"
                        Margin="0,1,0,0" />
                    <TextBlock x:Name="TxtProgress" Grid.Row="2"
                        Text="{Binding ProgressText}"
                        Foreground="{StaticResource TextDimmed}"
                        FontSize="9" Margin="0,2,0,0"
                        Visibility="{Binding IsConnected,
                        Converter={StaticResource
                            BoolToVisibilityConverter}}" />
                </Grid>

                <!-- Center Time (taskbar mode) -->
                <TextBlock x:Name="TxtCenterTime" Grid.Column="2"
                    Text="{Binding ProgressText}"
                    Foreground="{StaticResource TextSecondary}"
                    FontSize="9.5" VerticalAlignment="Center"
                    Margin="4,0,4,0" Visibility="Collapsed" />

                <!-- Playback Controls -->
                <StackPanel Grid.Column="3" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,2,0">
                    <Button x:Name="BtnPrev"
                        Style="{StaticResource ControlButton}"
                        Command="{Binding PreviousTrackCommand}"
                        Content="&#xE892;" ToolTip="Previous" />
                    <Button x:Name="BtnPlayPause"
                        Style="{StaticResource PlayPauseButton}"
                        Command="{Binding PlayPauseCommand}"
                        Content="{Binding PlayPauseIcon}"
                        ToolTip="Play / Pause" Margin="2,0" />
                    <Button x:Name="BtnNext"
                        Style="{StaticResource ControlButton}"
                        Command="{Binding NextTrackCommand}"
                        Content="&#xE893;" ToolTip="Next" />
                </StackPanel>

                <!-- Close -->
                <Button Grid.Column="4"
                    Style="{StaticResource CloseButton}"
                    Content="&#x2715;" Click="CloseButton_Click"
                    VerticalAlignment="Top" Margin="0,-4,-4,0"
                    ToolTip="Close" />
            </Grid>

            <!-- Progress Bar -->
            <Grid x:Name="ProgressBarGrid" Grid.Row="1"
                  Margin="0,4,0,0" Cursor="Hand"
                  Background="Transparent"
                  MouseLeftButtonDown="ProgressBar_Click">
                <Border Background="#1A1A32" CornerRadius="3"
                        Height="4" />
                <Border CornerRadius="3" HorizontalAlignment="Left"
                        Height="4">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0"
                                             EndPoint="1,0">
                            <GradientStop
                                Color="{StaticResource SpotifyGreenDark}"
                                Offset="0" />
                            <GradientStop
                                Color="{StaticResource SpotifyGreen}"
                                Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Width>
                        <MultiBinding Converter=
                            "{StaticResource ProgressWidthConverter}">
                            <Binding Path="ProgressPercent" />
                            <Binding Path="ActualWidth"
                                RelativeSource=
                                "{RelativeSource AncestorType=Grid}" />
                        </MultiBinding>
                    </Border.Width>
                </Border>
                <Canvas x:Name="ProgressDotCanvas" Height="4"
                        ClipToBounds="False">
                    <Ellipse x:Name="ProgressDot"
                             Width="8" Height="8" Canvas.Top="-2"
                             Fill="{StaticResource GreenBrush}"
                             Visibility="{Binding IsConnected,
                             Converter={StaticResource
                                 BoolToVisibilityConverter}}">
                        <Ellipse.Effect>
                            <DropShadowEffect
                                Color="{StaticResource SpotifyGreen}"
                                BlurRadius="6" ShadowDepth="0"
                                Opacity="0.5" />
                        </Ellipse.Effect>
                        <Canvas.Left>
                            <MultiBinding Converter=
                                "{StaticResource ProgressWidthConverter}">
                                <Binding Path="ProgressPercent" />
                                <Binding Path="ActualWidth"
                                    RelativeSource=
                                    "{RelativeSource
                                        AncestorType=Canvas}" />
                            </MultiBinding>
                        </Canvas.Left>
                    </Ellipse>
                </Canvas>
            </Grid>
        </Grid>
    </Border>
</Window>